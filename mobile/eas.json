{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote",
    "requireCommit": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "credentialsSource": "remote"
    },
    "preview": {
      "distribution": "internal",
      "credentialsSource": "remote",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "autoIncrement": true,
      "credentialsSource": "remote"
    }
  }
}
