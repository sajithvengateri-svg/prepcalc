{
  "expo": {
    "name": "Prep Cam",
    "slug": "prepcalc",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "prepcalc",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "au.prepmi.prepcalc",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "PrepCam needs camera access for the Anime Chef Studio feature."
      }
    },
    "android": {
      "package": "au.prepmi.prepcalc",
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF8",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "supabaseUrl": "https://twxysmsntweutblkfzdi.supabase.co",
      "supabaseAnonKey": "sb_publishable_SYCJwaryXxxtirbkUynfTw_8MmWGdtJ",
      "eas": {
        "projectId": "4c2ab2b7-d043-4531-a173-295c0558d0a1"
      },
      "router": {}
    },
    "owner": "prepcalc",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "PrepCam needs camera access for the Anime Chef Studio feature."
        }
      ]
    ]
  }
}
